# WalletDNA — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ─── Required ──────────────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key_here   # get from etherscan.io/apis

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=walletdna_secret              # change if needed

# ─── Optional ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                                  # DEBUG | INFO | WARNING | ERROR
